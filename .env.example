# Copier ce fichier en .env et remplir les valeurs

# Clé de chiffrement des clés API (générer avec : python -c "from engine.storage.crypto import generate_secret_key; print(generate_secret_key())")
# OBLIGATOIRE en production, optionnelle en dev (clé temporaire générée automatiquement)
WRITERAI_SECRET_KEY=

# Base de données
DATABASE_URL=sqlite+aiosqlite:///./writerai.db

# Dossier de stockage des projets
PROJECTS_DIR=./projects

# LLM par défaut (peut être surchargé par projet)
# --- Ollama (local, gratuit) ---
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_LLM_MODEL=qwen3:30b

# --- OpenAI ---
# DEFAULT_LLM_PROVIDER=openai
# DEFAULT_LLM_MODEL=gpt-4o

# --- Anthropic ---
# DEFAULT_LLM_PROVIDER=anthropic
# DEFAULT_LLM_MODEL=claude-opus-4-6

# Seuils de validation
MIN_VALIDATION_SCORE=7.0
MAX_REVISION_ATTEMPTS=5

# Redis (optionnel pour l'instant, nécessaire pour Celery)
REDIS_URL=redis://localhost:6379/0
